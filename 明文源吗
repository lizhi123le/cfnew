    function replaceWildcards(str) {
        return str
            .replace(/\$\{timestamp\}/g, Date.now())
            .replace(/\$\{random\}/g, Math.random().toString(36).substring(2, 8))
            .replace(/\$\{uuid\}/g, 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {
