                        showStatus('${isFarsi ? 'ШӘЩҲЩ„ЫҢШҜ ШҙШҜ' : 'е·Із”ҹжҲҗ'} ' + count + ' ${isFarsi ? 'IP ШӘШөШ§ШҜЩҒЫҢ CF' : 'дёӘCFйҡҸжңәIP'}', 'success');
                    });
