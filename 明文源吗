                        });
                    } else if (isIPv6) {
                        // еӨ„зҗҶжңӘеҠ дёӯжӢ¬еҸ·зҡ„ raw IPv6
                        const hashIndex = item.indexOf('#');
                        let hostPart = hashIndex > -1 ? item.substring(0, hashIndex) : item;
                        const remark = hashIndex > -1 ? item.substring(hashIndex + 1) : '';
                        
                        // з®ҖеҚ•еҲӨж–ӯжң«е°ҫжҳҜеҗҰеёҰз«ҜеҸЈ (еҰӮ :443)
                        const lastColonIndex = hostPart.lastIndexOf(':');
                        const possiblePort = hostPart.substring(lastColonIndex + 1);
                        let port = 443;
                        let ip = hostPart;
                        
                        if (lastColonIndex > 0 && /^\d+$/.test(possiblePort) && !hostPart.includes('::' + possiblePort)) {
                            port = parseInt(possiblePort, 10);
                            ip = hostPart.substring(0, lastColonIndex);
                        }
                        
                        results.push({
                            ip: ip,
                            port: port,
                            name: remark.trim() || ip
                        });
                    }
                }
                return results;
            }

            const response = await fetch(url);
            if (!response.ok) return [];
            const text = await response.text();
            const results = [];
            const lines = text.trim().replace(/\r/g, "").split('\n');
            const simpleRegex = /^([^:]+):(\d+)#(.*)$/;

            for (const line of lines) {
                const trimmedLine = line.trim();
                if (!trimmedLine) continue;
                const match = trimmedLine.match(simpleRegex);
                const isIPv6 = trimmedLine.includes(':') && (trimmedLine.split(':').length > 2);
                
                if (match) {
                    results.push({
                        ip: match[1],
                        port: parseInt(match[2], 10),
                        name: match[3].trim() || match[1]
                    });
                } else if (isIPv6) {
                    // еӨ„зҗҶж–Үжң¬жәҗдёӯзҡ„ raw IPv6 иЎҢ
                    const hashIndex = trimmedLine.indexOf('#');
                    let hostPart = hashIndex > -1 ? trimmedLine.substring(0, hashIndex) : trimmedLine;
                    const remark = hashIndex > -1 ? trimmedLine.substring(hashIndex + 1) : '';
                    
                    const lastColonIndex = hostPart.lastIndexOf(':');
                    const possiblePort = hostPart.substring(lastColonIndex + 1);
                    let port = 443;
                    let ip = hostPart;
                    
                    if (lastColonIndex > 0 && /^\d+$/.test(possiblePort) && !hostPart.includes('::' + possiblePort)) {
                        port = parseInt(possiblePort, 10);
                        ip = hostPart.substring(0, lastColonIndex);
                    }
                    
                    results.push({
                        ip: ip,
                        port: port,
                        name: remark.trim() || ip
                    });
                }
            }
            return results;
        } catch (error) {
            return [];
        }
    }

