            async function saveConfig(configData) {
                const apiUrl = window.location.pathname + '/api/config';

                try {
                    const response = await fetch(apiUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(configData)
                    });

                    if (response.status === 503) {
                        showStatus('KVеӯҳеӮЁжңӘй…ҚзҪ®пјҢж— жі•дҝқеӯҳй…ҚзҪ®гҖӮиҜ·е…ҲеңЁCloudflare Workersдёӯй…ҚзҪ®KVеӯҳеӮЁгҖӮ', 'error');
                        return;
                    }

                    if (!response.ok) {
                        const errorText = await response.text();

                        // е°қиҜ•и§Јжһҗ JSON й”ҷиҜҜдҝЎжҒҜ
                        try {
                            const errorData = JSON.parse(errorText);
                            showStatus(errorData.message || 'дҝқеӯҳеӨұиҙҘ', 'error');
                        } catch (parseError) {
                            // еҰӮжһңдёҚжҳҜ JSONпјҢзӣҙжҺҘжҳҫзӨәж–Үжң¬
                            showStatus('дҝқеӯҳеӨұиҙҘ: ' + errorText, 'error');
                        }
